  <script src="/_sdk/editing_sdk.js"></script>
  <script>
    // Stall numbers from spreadsheet: 93A-142B
    const stallNumbers = ['93A','93B','94A','94B','95A','95B','96A','96B','97A','97B','98A','98B','99A','99B','100A','100B','101A','101B','102A','102B','103A','103B','104A','104B','105A','105B','106A','106B','107A','107B','108A','108B','109A','109B','110A','110B','111A','111B','112A','112B','113A','113B','114A','114B','115A','115B','116A','116B','117A','117B','118A','118B','119A','119B','120A','120B','121A','121B','122A','122B','124/Pony Barn','129A','129B','130A','130B','131A','131B','132A','132B','133A','133B','134A','134B','135A','135B','140A','140B','141A','141B','142A','142B'];

    let records = [];
    let selectedStall = null;
    let selectedRecord = null;
    let editingRecord = null;
    let isSaving = false;

    const emptyPanel = document.getElementById('empty-panel');
    const detailsPanel = document.getElementById('details-panel');
    const modal = document.getElementById('modal');
    const form = document.getElementById('assignment-form');
    const stallSelect = document.getElementById('stall-number');
    const stallPicker = document.getElementById('stall-picker');
    const toast = document.getElementById('toast');
    const statusBadge = document.getElementById('stall-status-badge');
    const searchInput = document.getElementById('search-input');

    function populateSelects() {
      [stallSelect, stallPicker].forEach(sel => {
        sel.innerHTML = '';
        stallNumbers.forEach(s => {
          const o = document.createElement('option');
          o.value = s;
          o.textContent = `Stall ${s}`;
          sel.appendChild(o);
        });
      });
    }

    function filterStalls(query) {
      const lowerQuery = query.toLowerCase();
      const filtered = stallNumbers.filter(stall => {
        const rec = getRecordForStall(stall);
        return stall.toLowerCase().includes(lowerQuery) ||
               (rec && rec.horse_name && rec.horse_name.toLowerCase().includes(lowerQuery)) ||
               (rec && rec.owner_name && rec.owner_name.toLowerCase().includes(lowerQuery));
      });
      stallPicker.innerHTML = '';
      filtered.forEach(s => {
        const o = document.createElement('option');
        o.value = s;
        o.textContent = `Stall ${s}`;
        stallPicker.appendChild(o);
      });
      if (filtered.length > 0) stallPicker.value = filtered[0];
    }

    function getRecordForStall(stall) {
      return records.find(r => r.stall_number === stall) || null;
    }

    function updateStatusBadge() {
      if (!selectedStall) { statusBadge.textContent = ''; statusBadge.className = ''; return; }
      const rec = getRecordForStall(selectedStall);
      if (rec) {
        statusBadge.textContent = 'Occupied';
        statusBadge.className = 'rounded-full px-3 py-1 text-xs font-bold tracking-wide bg-[#dfe8dc] text-[#25432e]';
      } else {
        statusBadge.textContent = 'Available';
        statusBadge.className = 'rounded-full px-3 py-1 text-xs font-bold tracking-wide bg-[#f2e2c9] text-[#775434]';
      }
    }

    function selectStall(stall) {
      selectedStall = stall;
      selectedRecord = getRecordForStall(stall);
      updateStatusBadge();
      renderDetails();
    }

    function renderDetails() {
      if (!selectedStall) {
        emptyPanel.classList.remove('hidden');
        detailsPanel.classList.add('hidden');
        return;
      }
      emptyPanel.classList.add('hidden');
      detailsPanel.classList.remove('hidden');
      document.getElementById('delete-confirm').classList.add('hidden');
      document.getElementById('detail-stall').textContent = selectedStall;
      const status = document.getElementById('detail-status');

      if (selectedRecord) {
        status.textContent = 'Occupied';
        status.className = 'rounded-full px-3 py-1 text-xs font-bold tracking-wide bg-[#d9e6d7] text-[#24432d]';
        document.getElementById('detail-horse').textContent = selectedRecord.horse_name || '—';
        document.getElementById('detail-owner').textContent = selectedRecord.owner_name || '—';
        document.getElementById('detail-phone').textContent = selectedRecord.owner_phone || 'No phone listed';
        document.getElementById('detail-email').textContent = selectedRecord.owner_email || 'No email listed';
        document.getElementById('detail-notes').textContent = selectedRecord.notes || 'No care notes added yet.';
        document.getElementById('clear-button').disabled = false;
        document.getElementById('clear-button').classList.remove('opacity-50');
      } else {
        status.textContent = 'Available';
        status.className = 'rounded-full px-3 py-1 text-xs font-bold tracking-wide bg-[#f2e2c9] text-[#775434]';
        document.getElementById('detail-horse').textContent = 'No horse assigned';
        document.getElementById('detail-owner').textContent = '—';
        document.getElementById('detail-phone').textContent = 'No phone listed';
        document.getElementById('detail-email').textContent = 'No email listed';
        document.getElementById('detail-notes').textContent = 'This stall is available for a new assignment.';
        document.getElementById('clear-button').disabled = true;
        document.getElementById('clear-button').classList.add('opacity-50');
      }
    }

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 2600);
    }

    function openModal(record = null, preferredStall = null) {
      editingRecord = record;
      document.getElementById('form-message').classList.add('hidden');
      form.reset();
      if (record) {
        document.getElementById('modal-title').textContent = 'Edit assignment';
        stallSelect.value = record.stall_number;
        stallSelect.disabled = true;
        document.getElementById('horse-name').value = record.horse_name || '';
        document.getElementById('owner-name').value = record.owner_name || '';
        document.getElementById('owner-phone').value = record.owner_phone || '';
        document.getElementById('owner-email').value = record.owner_email || '';
        document.getElementById('notes').value = record.notes || '';
      } else {
        document.getElementById('modal-title').textContent = 'Add assignment';
        stallSelect.disabled = false;
        stallSelect.value = preferredStall || selectedStall || stallNumbers[0];
      }
      modal.classList.remove('hidden');
      setTimeout(() => document.getElementById('horse-name').focus(), 50);
    }

    function closeModal() {
      modal.classList.add('hidden');
      editingRecord = null;
      stallSelect.disabled = false;
      form.reset();
    }

    function setSavingState(active) {
      isSaving = active;
      document.getElementById('save-button').disabled = active;
      document.getElementById('cancel-form').disabled = active;
      document.getElementById('save-button').textContent = active ? 'Saving…' : 'Save assignment';
      document.getElementById('save-button').classList.toggle('opacity-70', active);
    }

    async function handleSubmit(event) {
      event.preventDefault();
      if (isSaving) return;
      const message = document.getElementById('form-message');
      message.classList.add('hidden');

      const payload = {
        stall_number: stallSelect.value,
        horse_name: document.getElementById('horse-name').value.trim(),
        owner_name: document.getElementById('owner-name').value.trim(),
        owner_phone: document.getElementById('owner-phone').value.trim(),
        owner_email: document.getElementById('owner-email').value.trim(),
        notes: document.getElementById('notes').value.trim()
      };

      if (!payload.horse_name || !payload.owner_name) {
        message.textContent = 'Please add both a horse name and owner name.';
        message.classList.remove('hidden');
        return;
      }
      if (!editingRecord && records.length >= 999) {
        message.textContent = 'The sheet is full. Please clear a stall before adding another assignment.';
        message.classList.remove('hidden');
        return;
      }
      const duplicate = records.find(r => r.stall_number === payload.stall_number && (!editingRecord || r.__backendId !== editingRecord.__backendId));
      if (duplicate) {
        message.textContent = 'That stall already has an assignment. Choose another or edit the existing one.';
        message.classList.remove('hidden');
        return;
      }

      setSavingState(true);
      let result;
      if (editingRecord) {
        result = await window.dataSdk.update({ ...editingRecord, ...payload });
      } else {
        result = await window.dataSdk.create(payload);
      }
      setSavingState(false);

      if (result.isOk) {
        closeModal();
        selectedStall = payload.stall_number;
        stallPicker.value = payload.stall_number;
        showToast(editingRecord ? 'Assignment updated.' : 'Assignment added.');
      } else {
        message.textContent = 'Could not save. Please try again.';
        message.classList.remove('hidden');
      }
    }

    async function deleteSelected() {
      if (!selectedRecord) return;
      const btn = document.getElementById('confirm-delete');
      btn.disabled = true;
      btn.textContent = 'Clearing…';
      const result = await window.dataSdk.delete(selectedRecord);
      btn.disabled = false;
      btn.textContent = 'Yes, clear stall';
      if (result.isOk) {
        showToast('Stall cleared.');
        document.getElementById('delete-confirm').classList.add('hidden');
      } else {
        showToast('Could not clear stall. Please try again.');
      }
    }

    function syncUI() {
      selectedRecord = selectedStall ? getRecordForStall(selectedStall) : null;
      updateStatusBadge();
      renderDetails();
    }

    function onSearchChange() {
      const query = searchInput.value;
      if (!query) {
        populateSelects();
      } else {
        filterStalls(query);
      }
      stallPicker.dispatchEvent(new Event('change'));
    }

    async function initData() {
      const handler = {
        onDataChanged(data) {
          records = Array.isArray(data) ? data : [];
          syncUI();
        }
      };
      const initResult = await window.dataSdk.init(handler);
      if (!initResult.isOk) showToast('Could not connect to the stable sheet.');
    }

    populateSelects();
    lucide.createIcons();

    searchInput.addEventListener('input', onSearchChange);
    stallPicker.addEventListener('change', () => selectStall(stallPicker.value));
    document.getElementById('open-add-modal').addEventListener('click', () => openModal(null, selectedStall));
    document.getElementById('edit-button').addEventListener('click', () => openModal(selectedRecord, selectedStall));
    document.getElementById('clear-button').addEventListener('click', () => { if (selectedRecord) document.getElementById('delete-confirm').classList.remove('hidden'); });
    document.getElementById('confirm-delete').addEventListener('click', deleteSelected);
    document.getElementById('cancel-delete').addEventListener('click', () => document.getElementById('delete-confirm').classList.add('hidden'));
    document.getElementById('close-modal').addEventListener('click', closeModal);
    document.getElementById('cancel-form').addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
    form.addEventListener('submit', handleSubmit);

    initData();
  </script>
